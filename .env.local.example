# Bungie API application (https://www.bungie.net/en/Application)
# OAuth type: Confidential. Redirect: https://127.0.0.1:3000/api/auth/callback
BUNGIE_API_KEY=
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=

# Local LLM — OpenAI-compatible (default; LM Studio, vLLM, etc.)
LLM_PROVIDER=openai
LLM_URL=http://127.0.0.1:1234/v1
LLM_MODEL=local-model
# LLM_API_KEY=   # optional Bearer token if your server requires auth

# Grok (xAI cloud) — uncomment to use Grok with optional local fallback
# LLM_PROVIDER=grok
# XAI_API_KEY=
# LLM_MODEL_GROK=grok-4.3
# Fallback when Grok is unavailable (pick one):
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=gemma4
# — or —
# LLM_URL=http://127.0.0.1:1234/v1
# LLM_MODEL=your-local-model-id

# Legacy Ollama (set LLM_PROVIDER=ollama or use these without LLM_* vars)
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=gemma4

# Self-hosted SearXNG (optional; JSON format must be enabled in settings.yml)
SEARXNG_URL=http://127.0.0.1:8888

# 32+ char random string for iron-session cookie encryption
SESSION_SECRET=

# Optional multi-pass LLM generation (5 specialist passes; slower, experimental)
LLM_MULTI_PASS_ENABLED=false

# DIM Sync API key for dim.gg loadout shares (optional; requires Bungie sign-in).
# Get a localhost dev key: see "Get an API key" in
# https://github.com/DestinyItemManager/dim-api#get-an-api-key
DIM_API_KEY=
