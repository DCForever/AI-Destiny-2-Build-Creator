# Bungie API application (https://www.bungie.net/en/Application)
# OAuth type: Confidential. Redirect: https://127.0.0.1:3000/api/auth/callback
BUNGIE_API_KEY=
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=

# Local LLM via Ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4

# Self-hosted SearXNG (optional; JSON format must be enabled in settings.yml)
SEARXNG_URL=http://127.0.0.1:8888

# 32+ char random string for iron-session cookie encryption
SESSION_SECRET=
